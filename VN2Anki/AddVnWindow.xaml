<Window x:Class="VN2Anki.AddVnWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Adicionar Nova Visual Novel" Height="650" Width="550"
        Background="#1E1E1E" Foreground="White" WindowStartupLocation="CenterOwner" WindowStyle="ToolWindow">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </Window.Resources>

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,15">
            <TextBlock Text="1. Selecione a janela da Visual Novel:" FontWeight="Bold" Margin="0,0,0,5" Foreground="#EAEAEA"/>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <ComboBox Grid.Column="0" ItemsSource="{Binding OpenWindows}" SelectedItem="{Binding SelectedWindow}" DisplayMemberPath="DisplayName" Padding="5" Margin="0,0,5,0"/>
                <Button Grid.Column="1" Content="🔄" Width="30" Command="{Binding LoadWindowsCommand}" ToolTip="Atualizar lista"/>
            </Grid>
        </StackPanel>

        <Border Grid.Row="1" Background="#2D2D30" CornerRadius="5" Padding="10" Margin="0,0,0,15" Visibility="{Binding HasThumbnail, Converter={StaticResource BoolToVis}}">
            <StackPanel>
                <TextBlock Text="Prévia da Janela:" FontWeight="SemiBold" Foreground="Gray" Margin="0,0,0,5"/>
                <Image Source="{Binding WindowThumbnail}" MaxHeight="120" Stretch="Uniform" HorizontalAlignment="Center"/>
            </StackPanel>
        </Border>

        <StackPanel Grid.Row="2" Margin="0,0,0,10">
            <TextBlock Text="2. Busca no VNDB (Romaji/Inglês):" FontWeight="Bold" Margin="0,0,0,5" Foreground="#EAEAEA"/>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox Grid.Column="0" Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}" Padding="5" Margin="0,0,10,0">
                    <TextBox.InputBindings>
                        <KeyBinding Key="Enter" Command="{Binding SearchVndbCommand}"/>
                    </TextBox.InputBindings>
                </TextBox>
                <Button Grid.Column="1" Content="Pesquisar" Command="{Binding SearchVndbCommand}" Padding="15,5" Background="#007ACC" Foreground="White" BorderThickness="0" Cursor="Hand"/>
            </Grid>
        </StackPanel>

        <Grid Grid.Row="3" Margin="0,0,0,15">
            <TextBlock Text="A carregar resultados..." Foreground="Gray" HorizontalAlignment="Center" VerticalAlignment="Center" Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}"/>

            <ListBox ItemsSource="{Binding SearchResults}" SelectedItem="{Binding SelectedVndbResult}" Background="#2D2D30" BorderThickness="0" Foreground="White" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Border Background="#3E3E42" CornerRadius="5" Margin="2" Padding="10" Width="470">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Image Grid.Column="0" Source="{Binding Image.Url}" Width="40" Height="50" Stretch="UniformToFill" Margin="0,0,10,0"/>
                                <TextBlock Grid.Column="1" Text="{Binding Title}" FontWeight="SemiBold" FontSize="14" TextWrapping="Wrap" VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Grid>

        <Button Grid.Row="4" Content="Confirmar e Guardar" Command="{Binding SaveAndCloseCommand}" CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}" Padding="10" Background="#28A745" Foreground="White" FontWeight="Bold" BorderThickness="0" Cursor="Hand"/>
    </Grid>
</Window>