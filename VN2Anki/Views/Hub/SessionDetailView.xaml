<UserControl x:Class="VN2Anki.Views.Hub.SessionDetailView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:VN2Anki.Views.Hub"
             xmlns:converters="clr-namespace:VN2Anki.Converters"
             xmlns:helpers="clr-namespace:VN2Anki.Helpers"
             xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
             mc:Ignorable="d" 
             d:DesignHeight="800" d:DesignWidth="1000"
             Background="Transparent">
    <UserControl.Resources>
        <helpers:BindingProxy x:Key="DataContextProxy" Data="{Binding}" />
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <converters:ImagePathConverter x:Key="ImagePathConverter"/>
        <converters:SecondsToFormattedTimeConverter x:Key="SecondsToTimeConverter"/>
        <converters:BooleanInverseConverter x:Key="BoolInv"/>
        <converters:BooleanInverseConverter x:Key="BoolInvToVis"/>

        <Style x:Key="InvertedBoolToVis" TargetType="FrameworkElement">
            <Setter Property="Visibility" Value="Collapsed"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding AnalyticsResult.MinedWords.Count}" Value="0">
                    <Setter Property="Visibility" Value="Visible"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="TextBlock" x:Key="StatHeader">
            <Setter Property="Foreground" Value="#A0A0A0"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>

        <Style TargetType="TextBlock" x:Key="StatValue">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="22"/>
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>

        <Style TargetType="Border" x:Key="StatCard">
            <Setter Property="Background" Value="#252525"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="16,12"/>
            <Setter Property="Margin" Value="0,0,12,0"/>
            <Setter Property="Width" Value="180"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="Black" BlurRadius="5" Opacity="0.3" ShadowDepth="2"/>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Button Style="{DynamicResource IconButtonStyle}" 
                    Command="{Binding DataContext.NavigateBackCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                    Width="40" Height="40" Margin="0,0,16,0" VerticalAlignment="Center">
                <iconPacks:PackIconMaterial Kind="ArrowLeft" Width="20" Height="20" Foreground="White"/>
            </Button>

            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                <TextBlock Text="{Binding Session.StartTime, StringFormat='dd/MM/yyyy HH:mm'}" FontSize="24" FontWeight="Bold" Foreground="White"/>
                <TextBlock Text="{Binding VisualNovel.Title}" FontSize="14" Foreground="#A0A0A0" Margin="0,2,0,0"
                           Visibility="{Binding VisualNovel, Converter={StaticResource BoolToVis}}"/>
            </StackPanel>

            <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="Modo Avançado" Foreground="White" VerticalAlignment="Center" Margin="0,0,10,0"/>
                <ToggleButton IsChecked="{Binding IsAdvancedView}" />
            </StackPanel>
        </Grid>

        <!-- Stats Grid -->
        <WrapPanel Grid.Row="1" Margin="0,0,0,20">
            <Border Style="{StaticResource StatCard}" Width="190">
                <StackPanel>
                    <TextBlock Text="Tempo Efetivo (Útil)" Style="{StaticResource StatHeader}"/>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                        <iconPacks:PackIconMaterial Kind="ClockCheckOutline" Width="18" Height="18" Foreground="#2ECC71" Margin="0,0,8,0" VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding Session.EffectiveDurationSeconds, Converter={StaticResource SecondsToTimeConverter}}" Style="{StaticResource StatValue}"/>
                    </StackPanel>
                    <TextBlock Foreground="#888" FontSize="11">
                        <Run Text="Leitura: "/>
                        <Run Text="{Binding AnalyticsResult.ReadingDurationSeconds, Mode=OneWay, Converter={StaticResource SecondsToTimeConverter}}" Foreground="#AAA"/>
                    </TextBlock>
                    <TextBlock Foreground="#888" FontSize="11">
                        <Run Text="Lookups: "/>
                        <Run Text="{Binding AnalyticsResult.LookupDurationSeconds, Mode=OneWay, Converter={StaticResource SecondsToTimeConverter}}" Foreground="#AAA"/>
                    </TextBlock>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource StatCard}" Width="190">
                <StackPanel>
                    <TextBlock Text="Tempo Desperdiçado" Style="{StaticResource StatHeader}"/>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                        <iconPacks:PackIconMaterial Kind="ClockRemoveOutline" Width="18" Height="18" Foreground="#E74C3C" Margin="0,0,8,0" VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding AnalyticsResult.AfkDurationSeconds, Converter={StaticResource SecondsToTimeConverter}}" Style="{StaticResource StatValue}"/>
                    </StackPanel>
                    <TextBlock Foreground="#888" FontSize="11">
                        <Run Text="Distrações (AFK): "/>
                        <Run Text="{Binding AnalyticsResult.AfkDurationSeconds, Mode=OneWay, Converter={StaticResource SecondsToTimeConverter}}" Foreground="#AAA"/>
                    </TextBlock>
                    <TextBlock Foreground="#888" FontSize="11">
                        <Run Text="Overhead (Delay): "/>
                        <Run Text="{Binding AnalyticsResult.LatencySeconds, Mode=OneWay, Converter={StaticResource SecondsToTimeConverter}}" Foreground="#AAA"/>
                    </TextBlock>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource StatCard}" Width="150">
                <StackPanel>
                    <TextBlock Text="Consultas / Mined" Style="{StaticResource StatHeader}"/>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                        <iconPacks:PackIconMaterial Kind="BookSearchOutline" Width="18" Height="18" Foreground="#F39C12" Margin="0,0,8,0" VerticalAlignment="Center"/>
                        <TextBlock Style="{StaticResource StatValue}">
                            <Run Text="{Binding AnalyticsResult.LookupCount, Mode=OneWay}"/>
                            <Run Text="/" Foreground="#666"/>
                            <Run Text="{Binding AnalyticsResult.MiningCount, Mode=OneWay}" Foreground="#2ECC71"/>
                        </TextBlock>
                    </StackPanel>
                    <TextBlock Foreground="#888" FontSize="11">
                        <Run Text="Distrações Totais: "/>
                        <Run Text="{Binding AnalyticsResult.DistractionCount, Mode=OneWay}" Foreground="#E74C3C" FontWeight="Bold"/>
                    </TextBlock>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource StatCard}" Width="170">
                <StackPanel>
                    <TextBlock Text="Velocidade (Leitura)" Style="{StaticResource StatHeader}"/>
                    <StackPanel Orientation="Horizontal">
                        <iconPacks:PackIconMaterial Kind="Speedometer" Width="18" Height="18" Foreground="#9B59B6" Margin="0,0,8,0" VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding AnalyticsResult.CharsPerHour}" Style="{StaticResource StatValue}"/>
                        <TextBlock Text=" chars/h" Foreground="#666" FontSize="12" VerticalAlignment="Bottom" Margin="4,0,0,4"/>
                    </StackPanel>
                    <TextBlock Foreground="#888" FontSize="11" Margin="0,4,0,0">
                        <Run Text="Total: "/>
                        <Run Text="{Binding Session.CharactersRead, Mode=OneWay}" Foreground="#AAA"/>
                        <Run Text=" chars"/>
                    </TextBlock>
                </StackPanel>
            </Border>
        </WrapPanel>

        <!-- Main Content -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="300"/>
            </Grid.ColumnDefinitions>

            <!-- Log DataGrid -->
            <Border Grid.Column="0" Background="#1A1A1A" CornerRadius="8" Margin="0,0,16,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Background="#252525" CornerRadius="8,8,0,0" Padding="12">
                        <Grid>
                            <TextBlock Text="Histórico de Frases" Foreground="White" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center"/>
                            <Button HorizontalAlignment="Right" Padding="12,4" Background="#E74C3C" Foreground="White" BorderThickness="0"
                                    Command="{Binding DeleteItemsCommand}" CommandParameter="{Binding SelectedItems, ElementName=LogDataGrid}">
                                <iconPacks:PackIconMaterial Kind="Delete" Width="14" Height="14"/>
                            </Button>
                        </Grid>
                    </Border>

                    <DataGrid x:Name="LogDataGrid" Grid.Row="1" ItemsSource="{Binding FilteredLogItems}" AutoGenerateColumns="False" 
                              CanUserAddRows="False" CanUserDeleteRows="False" SelectionMode="Extended"
                              Background="Transparent" RowBackground="Transparent" AlternatingRowBackground="#12FFFFFF"
                              Foreground="White" HeadersVisibility="Column" GridLinesVisibility="None"
                              BorderThickness="0" VirtualizingPanel.IsVirtualizing="True" VirtualizingPanel.VirtualizationMode="Recycling">
                        <DataGrid.Resources>
                            <Style TargetType="DataGridColumnHeader">
                                <Setter Property="Background" Value="#252525"/>
                                <Setter Property="Foreground" Value="#A0A0A0"/>
                                <Setter Property="Padding" Value="10,8"/>
                                <Setter Property="BorderThickness" Value="0"/>
                            </Style>
                            <Style TargetType="DataGridRow">
                                <Setter Property="BorderThickness" Value="0"/>
                            </Style>
                            <Style TargetType="DataGridCell">
                                <Setter Property="Padding" Value="10,6"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="DataGridCell">
                                            <Border Padding="{TemplateBinding Padding}" Background="{TemplateBinding Background}">
                                                <ContentPresenter VerticalAlignment="Center" />
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </DataGrid.Resources>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Hora" Binding="{Binding Timestamp, StringFormat='HH:mm:ss'}" Width="80" IsReadOnly="True"/>
                            <DataGridTextColumn Header="Evento" Binding="{Binding EventType}" Width="80" IsReadOnly="True" 
                                                Visibility="{Binding Data.IsAdvancedView, Source={StaticResource DataContextProxy}, Converter={StaticResource BoolToVis}}"/>
                            
                            <DataGridTextColumn Header="Tempo Útil" Binding="{Binding ActiveSeconds, StringFormat='{}{0:F1}s'}" Width="90" IsReadOnly="True"
                                                Visibility="{Binding Data.IsAdvancedView, Source={StaticResource DataContextProxy}, Converter={StaticResource BoolInvToVis}}">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="#2ECC71"/>
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>

                            <DataGridTextColumn Header="Descontado" Binding="{Binding WastedSeconds, StringFormat='{}{0:F1}s'}" Width="90" IsReadOnly="True"
                                                Visibility="{Binding Data.IsAdvancedView, Source={StaticResource DataContextProxy}, Converter={StaticResource BoolInvToVis}}">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="#E74C3C"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>

                            <DataGridTextColumn Header="Conteúdo" Binding="{Binding Details}" Width="*" IsReadOnly="True">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="TextWrapping" Value="Wrap"/>
                                        <Setter Property="FontSize" Value="14"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                        </DataGrid.Columns>
                    </DataGrid>

                    <ProgressBar Grid.Row="1" IsIndeterminate="True" Height="2" VerticalAlignment="Top" 
                                 Visibility="{Binding IsLoadingLogs, Converter={StaticResource BoolToVis}}" Background="Transparent" Foreground="#4A90E2" BorderThickness="0"/>
                </Grid>
            </Border>

            <!-- Right Sidebar -->
            <StackPanel Grid.Column="1">
                <!-- Mined Words -->
                <Border Background="#1A1A1A" CornerRadius="8" Padding="12" Margin="0,0,0,16" MinHeight="200">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Text="Palavras Mineradas" Foreground="White" FontWeight="Bold" Margin="0,0,0,12"/>
                        
                        <ListBox Grid.Row="1" ItemsSource="{Binding AnalyticsResult.MinedWords}" Background="Transparent" BorderThickness="0">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#252525" CornerRadius="4" Padding="8,4" Margin="0,0,0,4">
                                        <TextBlock Text="{Binding}" Foreground="#2ECC71" FontSize="13"/>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                        
                        <TextBlock Grid.Row="1" Text="Nenhuma palavra minerada nesta sessão." Foreground="#555" 
                                   HorizontalAlignment="Center" VerticalAlignment="Center" TextWrapping="Wrap" TextAlignment="Center"
                                   Style="{StaticResource InvertedBoolToVis}"/>
                    </Grid>
                </Border>

                <!-- Speed Info / Placeholder for Gaussian -->
                <Border Background="#1A1A1A" CornerRadius="8" Padding="12">
                    <StackPanel>
                        <TextBlock Text="Ritmo de Leitura" Foreground="White" FontWeight="Bold" Margin="0,0,0,12"/>
                        
                        <!-- Simple Summary of Speed -->
                        <Grid Margin="0,0,0,10">
                            <TextBlock Text="Velocidade" Foreground="#A0A0A0"/>
                            <TextBlock Text="{Binding AnalyticsResult.CharsPerHour, StringFormat='{}{0} chars/h'}" Foreground="White" HorizontalAlignment="Right" FontWeight="Bold"/>
                        </Grid>
                        
                        <Border Height="100" Background="#05000000" BorderBrush="#333" BorderThickness="1" CornerRadius="4" ClipToBounds="True">
                            <Grid>
                                <Polygon Points="{Binding SpeedDistributionPoints}" 
                                         Fill="#339B59B6" 
                                         Stroke="#9B59B6" 
                                         StrokeThickness="2" 
                                         Stretch="Fill"
                                         Visibility="{Binding HasSpeedDistribution, Converter={StaticResource BoolToVis}}"/>
                                <TextBlock Text="Dados insuficientes para o gráfico." Foreground="#444" 
                                           VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="10">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding HasSpeedDistribution}" Value="False">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Grid>
                        </Border>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>