<UserControl x:Class="VN2Anki.Views.Hub.SessionDetailView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:VN2Anki.Views.Hub"
             xmlns:converters="clr-namespace:VN2Anki.Converters"
             xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="800"
             Background="Transparent">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <converters:ImagePathConverter x:Key="ImagePathConverter"/>

        <Style TargetType="TextBlock" x:Key="StatHeader">
            <Setter Property="Foreground" Value="#A0A0A0"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>

        <Style TargetType="TextBlock" x:Key="StatValue">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="24"/>
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>

        <Style TargetType="Border" x:Key="StatCard">
            <Setter Property="Background" Value="#252525"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="16"/>
            <Setter Property="Margin" Value="0,0,16,0"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="Black" BlurRadius="5" Opacity="0.3" ShadowDepth="2"/>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Button Style="{DynamicResource IconButtonStyle}" 
                    Command="{Binding DataContext.NavigateBackCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                    Width="40" Height="40" Margin="0,0,16,0" VerticalAlignment="Center">
                <iconPacks:PackIconMaterial Kind="ArrowLeft" Width="20" Height="20" Foreground="White"/>
            </Button>

            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                <TextBlock Text="{Binding Session.StartTime, StringFormat='dd/MM/yyyy HH:mm'}" FontSize="28" FontWeight="Bold" Foreground="White"/>
                <TextBlock Text="{Binding VisualNovel.Title}" FontSize="16" Foreground="#A0A0A0" Margin="0,4,0,0"
                           Visibility="{Binding VisualNovel, Converter={StaticResource BoolToVis}}"/>
            </StackPanel>
        </Grid>

        <!-- Stats Cards -->
        <ScrollViewer Grid.Row="1" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled" Margin="0,0,0,20">
            <StackPanel Orientation="Horizontal">
                <!-- Total Time -->
                <Border Style="{StaticResource StatCard}" Width="160">
                    <StackPanel>
                        <TextBlock Text="Tempo Total" Style="{StaticResource StatHeader}"/>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Bottom">
                            <iconPacks:PackIconMaterial Kind="ClockOutline" Width="24" Height="24" Foreground="#4A90E2" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding Session.FormattedDuration}" Style="{StaticResource StatValue}"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Effective Time -->
                <Border Style="{StaticResource StatCard}" Width="160">
                    <StackPanel>
                        <TextBlock Text="Tempo Efetivo" Style="{StaticResource StatHeader}"/>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Bottom">
                            <iconPacks:PackIconMaterial Kind="ClockCheckOutline" Width="24" Height="24" Foreground="#2ECC71" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding Session.EffectiveDurationSeconds}" Style="{StaticResource StatValue}"/>
                            <!-- Formatter missing for int seconds to timespan string, will just show raw or we can make a property in ViewModel -->
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Characters -->
                <Border Style="{StaticResource StatCard}" Width="160">
                    <StackPanel>
                        <TextBlock Text="Caracteres Lidos" Style="{StaticResource StatHeader}"/>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Bottom">
                            <iconPacks:PackIconMaterial Kind="TextShadow" Width="24" Height="24" Foreground="#F39C12" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding Session.CharactersRead}" Style="{StaticResource StatValue}"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Lookups -->
                <Border Style="{StaticResource StatCard}" Width="160">
                    <StackPanel>
                        <TextBlock Text="Consultas (Yomitan)" Style="{StaticResource StatHeader}"/>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Bottom">
                            <iconPacks:PackIconMaterial Kind="BookSearchOutline" Width="24" Height="24" Foreground="#E74C3C" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding Session.LookupCount}" Style="{StaticResource StatValue}"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- Log List -->
        <Border Grid.Row="2" Background="#1A1A1A" CornerRadius="8" Padding="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Background="#252525" Margin="0,0,0,1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Histórico de Eventos" Foreground="White" FontSize="14" FontWeight="SemiBold" Margin="12,12"/>
                    
                    <Button Grid.Column="1" Margin="8" Padding="12,6" Background="#E74C3C" Foreground="White" BorderThickness="0"
                            Command="{Binding DeleteItemsCommand}" CommandParameter="{Binding SelectedItems, ElementName=LogDataGrid}">
                        <StackPanel Orientation="Horizontal">
                            <iconPacks:PackIconMaterial Kind="Delete" Width="14" Height="14" Margin="0,0,6,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Excluir Selecionados" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </Grid>

                <DataGrid x:Name="LogDataGrid" Grid.Row="1" ItemsSource="{Binding LogItems}" AutoGenerateColumns="False" 
                          CanUserAddRows="False" CanUserDeleteRows="False" SelectionMode="Extended"
                          Background="Transparent" RowBackground="Transparent" AlternatingRowBackground="#151515"
                          Foreground="White" HeadersVisibility="Column" GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#333333"
                          BorderThickness="0" VirtualizingPanel.IsVirtualizing="True" VirtualizingPanel.VirtualizationMode="Recycling">
                    <DataGrid.Resources>
                        <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#3D3D3D"/>
                        <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}" Color="#3D3D3D"/>
                        <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="White"/>
                        <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightTextBrushKey}" Color="White"/>

                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background" Value="#252525"/>
                            <Setter Property="Foreground" Value="#A0A0A0"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                            <Setter Property="Padding" Value="12,8"/>
                            <Setter Property="BorderThickness" Value="0,0,0,1"/>
                            <Setter Property="BorderBrush" Value="#333333"/>
                        </Style>
                        <Style TargetType="DataGridRow">
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="Background" Value="Transparent"/>
                        </Style>
                        <Style TargetType="DataGridCell">
                            <Setter Property="Padding" Value="12,8"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="DataGridCell">
                                        <Border Padding="{TemplateBinding Padding}" Background="{TemplateBinding Background}">
                                            <ContentPresenter VerticalAlignment="Center" />
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </DataGrid.Resources>
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Linha" Binding="{Binding LineIndex}" Width="Auto" IsReadOnly="True"/>
                        <DataGridTextColumn Header="Hora" Binding="{Binding Timestamp, StringFormat='HH:mm:ss'}" Width="Auto" IsReadOnly="True"/>
                        <DataGridTextColumn Header="Evento" Binding="{Binding EventType}" Width="Auto" IsReadOnly="True"/>
                        <DataGridTextColumn Header="Detalhes / Texto" Binding="{Binding Details}" Width="*" IsReadOnly="True">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="TextWrapping" Value="Wrap"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                    </DataGrid.Columns>
                </DataGrid>

                <StackPanel Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Center" 
                            Visibility="{Binding IsLoadingLogs, Converter={StaticResource BoolToVis}}">
                    <TextBlock Text="Carregando Log..." Foreground="#A0A0A0" FontSize="16"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>