<UserControl x:Class="VN2Anki.Views.Hub.VnDetailsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:VN2Anki.Converters"
             xmlns:loc="clr-namespace:VN2Anki.Locales"
             xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
             Background="Transparent"
             VerticalContentAlignment="Stretch">

    <UserControl.Resources>
        <conv:ImagePathConverter x:Key="ImgPathConverter"/>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        
        <Style x:Key="StatTileStyle" TargetType="Border">
            <Setter Property="Background" Value="#2D2D30"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="15"/>
            <Setter Property="Margin" Value="0,0,15,0"/>
            <Setter Property="MinWidth" Value="140"/>
        </Style>

        <Style x:Key="GraphButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#3F3F46"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="10"/>
            <Setter Property="Margin" Value="0,0,10,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#505058"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <!-- 0: Navigation/Actions -->
            <RowDefinition Height="Auto"/> <!-- 1: Header (Capa + Info) -->
            <RowDefinition Height="*"/>    <!-- 2: Corpo (Histórico + Gráficos) -->
        </Grid.RowDefinitions>

        <!-- 0: NAVEGAÇÃO E AÇÕES -->
        <Grid Grid.Row="0" Margin="0,0,0,30" VerticalAlignment="Top">
            <Button Command="{Binding GoBackCommand}" Content="← Back" Background="Transparent" Foreground="#888888" BorderThickness="0" 
                    HorizontalAlignment="Left" FontSize="14" Cursor="Hand" VerticalAlignment="Center"/>
            
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                <Button Command="{Binding PlayVnCommand}" Content="▶ Play" Background="#007ACC" Foreground="White" FontWeight="Bold" BorderThickness="0" Padding="15,6" Margin="0,0,10,0" Cursor="Hand">
                    <Button.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="4"/></Style></Button.Resources>
                </Button>
                <Button Command="{Binding OpenEditModalCommand}" Content="⚙️ Edit" Background="#3F3F46" Foreground="White" BorderThickness="0" Padding="12,6" Margin="0,0,10,0" Cursor="Hand">
                    <Button.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="4"/></Style></Button.Resources>
                </Button>
                <Button Command="{Binding DeleteVnCommand}" Content="🗑️ Delete" Background="#DC3545" Foreground="White" BorderThickness="0" Padding="12,6" Cursor="Hand">
                    <Button.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="4"/></Style></Button.Resources>
                </Button>
            </StackPanel>
        </Grid>

        <!-- 1: HEADER (CAPA + INFO) -->
        <Grid Grid.Row="1" Margin="0,0,0,30" VerticalAlignment="Top">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Capa Portrait -->
            <Border Grid.Column="0" Width="180" Height="250" CornerRadius="8" ClipToBounds="True" Background="#252526" Margin="0,0,30,0" VerticalAlignment="Top">
                <Image Source="{Binding Vn.CoverImagePath, Converter={StaticResource ImgPathConverter}}" Stretch="UniformToFill" VerticalAlignment="Top"/>
            </Border>

            <!-- Título e Stats -->
            <StackPanel Grid.Column="1" VerticalAlignment="Top">
                <TextBlock Foreground="White" FontWeight="Black" FontSize="44" 
                           TextTrimming="CharacterEllipsis" 
                           Padding="0" Margin="0" 
                           LineHeight="44"
                           LineStackingStrategy="BlockLineHeight"
                           VerticalAlignment="Top">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Text" Value="{Binding Vn.OriginalTitle}" />
                            <Setter Property="Visibility" Value="Visible" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Vn.OriginalTitle}" Value="{x:Null}">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding Vn.OriginalTitle}" Value="">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
                
                <TextBlock Text="{Binding Vn.Title}" 
                           Foreground="#888888" FontSize="22" 
                           Margin="0,8,0,25" 
                           VerticalAlignment="Top"/>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Top">
                    <Border Style="{StaticResource StatTileStyle}" VerticalAlignment="Top">
                        <StackPanel>
                            <TextBlock Text="⏱ HOURS" Foreground="#888888" FontWeight="Bold" FontSize="11"/>
                            <TextBlock Text="{Binding Vn.FormattedTotalTime}" Foreground="#007ACC" FontWeight="Black" FontSize="28" Margin="0,5,0,0"/>
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource StatTileStyle}" VerticalAlignment="Top">
                        <StackPanel>
                            <TextBlock Text="🅰 CHARS" Foreground="#888888" FontWeight="Bold" FontSize="11"/>
                            <TextBlock Text="{Binding Vn.TotalCharactersRead}" Foreground="#28A745" FontWeight="Black" FontSize="28" Margin="0,5,0,0"/>
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource StatTileStyle}" VerticalAlignment="Top">
                        <StackPanel>
                            <TextBlock Text="🚀 SPEED" Foreground="#888888" FontWeight="Bold" FontSize="11"/>
                            <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                                <TextBlock Text="{Binding AverageSpeed, StringFormat={}{0:F0}}" Foreground="#FFC107" FontWeight="Black" FontSize="28"/>
                                <TextBlock Text=" c/h" Foreground="#666666" FontSize="12" VerticalAlignment="Bottom" Margin="4,0,0,4"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </StackPanel>
        </Grid>

        <!-- 2: CORPO (HISTÓRICO + AVANÇADO) -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="350"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Histórico -->
            <Border Grid.Column="0" Background="#252526" CornerRadius="8" Padding="15" Margin="0,0,20,0">
                <DockPanel LastChildFill="True">
                    <TextBlock DockPanel.Dock="Top" Text="RECENT SESSIONS" Foreground="#888888" FontSize="14" FontWeight="Bold" Margin="0,0,0,15"/>
                    <ItemsControl ItemsSource="{Binding RecentSessions}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="#3E3E42" BorderThickness="0,0,0,1" Padding="0,10">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="{Binding EndTime, StringFormat='{}{0:dd MMM yyyy}'}" Foreground="#666666" FontSize="11"/>
                                            <TextBlock Text="{Binding FormattedDuration}" Foreground="White" FontWeight="SemiBold" FontSize="14"/>
                                        </StackPanel>
                                        <TextBlock Grid.Column="1" Text="{Binding CharactersRead, StringFormat='{} {0} chars'}" Foreground="#28A745" FontWeight="Bold" VerticalAlignment="Center"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </DockPanel>
            </Border>

            <!-- Status Avançado -->
            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,15">
                    <Button Style="{StaticResource GraphButtonStyle}" Command="{Binding SetGraphTypeCommand}" CommandParameter="HeatMap" ToolTip="Session HeatMap">
                        <iconPacks:PackIconMaterial Kind="CalendarMonth" Width="18" Height="18"/>
                    </Button>
                    <Button Style="{StaticResource GraphButtonStyle}" Command="{Binding SetGraphTypeCommand}" CommandParameter="CharsProgress" ToolTip="Characters Progress">
                        <iconPacks:PackIconMaterial Kind="ChartTimelineVariant" Width="18" Height="18"/>
                    </Button>
                    <Button Style="{StaticResource GraphButtonStyle}" Command="{Binding SetGraphTypeCommand}" CommandParameter="TimeProgress" ToolTip="Hours Played Progress">
                        <iconPacks:PackIconMaterial Kind="ChartLine" Width="18" Height="18"/>
                    </Button>
                </StackPanel>

                <Border Grid.Row="1" Background="#1A1A1C" CornerRadius="8" BorderBrush="#3E3E42" BorderThickness="1" MinHeight="200">
                    <Grid>
                        <TextBlock Text="{Binding CurrentGraphType, StringFormat='{}Graph: {0}'}" Foreground="#444444" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="20" FontWeight="Bold"/>
                    </Grid>
                </Border>
            </Grid>
        </Grid>

        <!-- MODAL DE EDIÇÃO -->
        <Grid Grid.RowSpan="3" Background="#CC000000" Visibility="{Binding IsEditModalOpen, Converter={StaticResource BoolToVis}}" Panel.ZIndex="100" Margin="-20">
            <Border Background="#1E1E1E" BorderBrush="#3E3E42" BorderThickness="1" CornerRadius="8" Width="400" HorizontalAlignment="Center" VerticalAlignment="Center" Padding="20">
                <StackPanel>
                    <TextBlock Text="Edit Visual Novel" Foreground="White" FontSize="18" FontWeight="Bold" Margin="0,0,0,20"/>
                    <TextBlock Text="Executable Path" Foreground="#AAAAAA" FontWeight="SemiBold" Margin="0,0,0,5"/>
                    <TextBox Text="{Binding EditExecutablePath}" Background="#2D2D30" Foreground="White" BorderThickness="0" Padding="8" Margin="0,0,0,15"/>
                    <TextBlock Text="VNDB ID (Ex: v1143)" Foreground="#AAAAAA" FontWeight="SemiBold" Margin="0,0,0,5"/>
                    <TextBox Text="{Binding EditVndbId}" Background="#2D2D30" Foreground="White" BorderThickness="0" Padding="8" Margin="0,0,0,25"/>
                    <Grid>
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                        <Button Grid.Column="0" Content="Cancel" Command="{Binding CloseEditModalCommand}" Background="Transparent" Foreground="#CCCCCC" BorderThickness="0" Padding="10" Margin="0,0,5,0" Cursor="Hand"/>
                        <Button Grid.Column="1" Content="Save" Command="{Binding SaveEditCommand}" Background="#007ACC" Foreground="White" FontWeight="Bold" BorderThickness="0" Padding="10" Margin="5,0,0,0" Cursor="Hand"/>
                    </Grid>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
