<UserControl x:Class="VN2Anki.Views.Hub.LibraryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:VN2Anki.Converters"
             Background="Transparent">

    <UserControl.Resources>
        <conv:ImagePathConverter x:Key="ImgPathConverter"/>
    </UserControl.Resources>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Button Grid.Row="0" Content="+ Adicionar Jogo a partir do VNDB" Click="BtnAddVn_Click" Padding="15,8" Background="#007ACC" Foreground="White" FontWeight="Bold" BorderThickness="0" Cursor="Hand" HorizontalAlignment="Left" Margin="0,0,0,15"/>

        <ListBox Grid.Row="1" ItemsSource="{Binding VisualNovels}" Background="Transparent" BorderThickness="0" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
            <ListBox.ItemsPanel>
                <ItemsPanelTemplate>
                    <WrapPanel Orientation="Horizontal" />
                </ItemsPanelTemplate>
            </ListBox.ItemsPanel>

            <ListBox.ItemTemplate>
                
                    <DataTemplate>
                        <Border Background="#2D2D30" CornerRadius="8" Margin="10" Width="200" Height="370" ClipToBounds="True" Cursor="Hand">

                            <Border.InputBindings>
                                <MouseBinding Gesture="LeftClick" Command="{Binding DataContext.GoToDetailsCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}" />
                            </Border.InputBindings>

                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="220"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <Image Source="{Binding CoverImagePath, Converter={StaticResource ImgPathConverter}}" Stretch="UniformToFill" Grid.Row="0"/>
                                <Border Grid.Row="0" BorderBrush="#3E3E42" BorderThickness="0,0,0,2"/>

                                <StackPanel Grid.Row="1" Margin="10">
                                    <TextBlock Text="{Binding Title}" Foreground="White" FontWeight="Bold" FontSize="14" TextTrimming="CharacterEllipsis" ToolTip="{Binding Title}"/>
                                    <TextBlock Text="{Binding ProcessName, StringFormat='Processo: {0}'}" Foreground="#AAAAAA" FontSize="11" Margin="0,2,0,8" TextTrimming="CharacterEllipsis"/>

                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                                        <TextBlock Text="⏱ " Foreground="#007ACC" FontSize="12"/>
                                        <TextBlock Text="{Binding FormattedTotalTime}" Foreground="#CCCCCC" FontSize="12" Margin="0,0,10,0"/>
                                        <TextBlock Text="A " Foreground="#28A745" FontSize="12"/>
                                        <TextBlock Text="{Binding TotalCharactersRead}" Foreground="#CCCCCC" FontSize="12"/>
                                    </StackPanel>

                                    <Grid Margin="0,5,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <Button Grid.Column="0" Content="▶ Play" Command="{Binding DataContext.PlayVnCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}" Background="#007ACC" Foreground="White" FontWeight="Bold" BorderThickness="0" Padding="5" Cursor="Hand" Margin="0,0,5,0"/>
                                        <Button Grid.Column="1" Content="🗑" Command="{Binding DataContext.DeleteVnCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}" Background="#DC3545" Foreground="White" BorderThickness="0" Padding="8,5" Cursor="Hand" ToolTip="Remover"/>
                                    </Grid>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
               
            </ListBox.ItemTemplate>
        </ListBox>
    </Grid>
</UserControl>