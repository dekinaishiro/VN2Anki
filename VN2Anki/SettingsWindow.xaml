<Window x:Class="VN2Anki.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:loc="clr-namespace:VN2Anki.Locales"
        xmlns:colorpicker="clr-namespace:ColorPicker;assembly=ColorPicker"
        Title="{x:Static loc:Strings.LblSettingsWindow}" Height="625" Width="575"
        Background="#252526" Foreground="White" WindowStartupLocation="CenterScreen" WindowStyle="ToolWindow"
        Topmost="True">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/ColorPicker;component/Styles/DefaultColorPickerStyle.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <Style x:Key="StandardTextBlock" TargetType="TextBlock">
                <Setter Property="Foreground" Value="#EAEAEA"/>
                <Setter Property="Margin" Value="5"/>
            </Style>

            <Style x:Key="StandardComboBox" TargetType="ComboBox">
                <Setter Property="Margin" Value="5"/>
                <Setter Property="Padding" Value="5"/>
                <Style.Triggers>
                    <Trigger Property="IsEnabled" Value="False">
                        <Setter Property="Opacity" Value="0.5"/>
                    </Trigger>
                </Style.Triggers>
            </Style>

            <Style x:Key="StandardButton" TargetType="Button">
                <Setter Property="Margin" Value="5"/>
                <Setter Property="Padding" Value="10,8"/>
                <Setter Property="Background" Value="#3F3F46"/>
                <Setter Property="Foreground" Value="White"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Style.Triggers>
                    <Trigger Property="IsEnabled" Value="False">
                        <Setter Property="Opacity" Value="0.5"/>
                        <Setter Property="Background" Value="#222222"/>
                        <Setter Property="Foreground" Value="#888888"/>
                    </Trigger>
                </Style.Triggers>
            </Style>

            <Style x:Key="SaveButton" TargetType="Button" BasedOn="{StaticResource StandardButton}">
                <Setter Property="Background" Value="#28A745"/>
                <Setter Property="Height" Value="40"/>
                <Setter Property="FontSize" Value="14"/>
                <Setter Property="Margin" Value="0,20,0,0"/>
            </Style>
        </ResourceDictionary>
    </Window.Resources>

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TabControl Background="Transparent" BorderThickness="0" Grid.Row="0">
            <TabControl.Resources>
                <Style TargetType="TabItem">
                    <Setter Property="Background" Value="#3F3F46"/>
                    <Setter Property="Foreground" Value="#EAEAEA"/>
                    <Setter Property="Padding" Value="20,10"/>
                    <Setter Property="Margin" Value="0,0,2,0"/>
                    <Setter Property="FontSize" Value="14"/>
                    <Setter Property="FontWeight" Value="SemiBold"/>
                    <Setter Property="Cursor" Value="Hand"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="TabItem">
                                <Border Name="TabBorder" 
                                        Background="{TemplateBinding Background}" 
                                        BorderThickness="0" 
                                        CornerRadius="4,4,0,0" 
                                        Padding="{TemplateBinding Padding}" 
                                        Margin="{TemplateBinding Margin}">
                                    <ContentPresenter HorizontalAlignment="Center" 
                                                      VerticalAlignment="Center" 
                                                      ContentSource="Header"/>
                                </Border>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                    <Style.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Background" Value="#007ACC"/>
                            <Setter Property="Foreground" Value="White"/>
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="#4d4d53"/>
                        </Trigger>
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsSelected" Value="True"/>
                                <Condition Property="IsMouseOver" Value="True"/>
                            </MultiTrigger.Conditions>
                            <Setter Property="Background" Value="#007ACC"/>
                        </MultiTrigger>
                    </Style.Triggers>
                </Style>
            </TabControl.Resources>

            <TabItem Header="{x:Static loc:Strings.HeaderConfig}">
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <Grid Margin="0,15,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Style="{StaticResource StandardTextBlock}" Text="{x:Static loc:Strings.LblAudioSource}" Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" FontWeight="Normal"/>
                        <ComboBox Style="{StaticResource StandardComboBox}" x:Name="ComboAudio" Grid.Row="0" Grid.Column="1" ItemsSource="{Binding AudioDevices}" DisplayMemberPath="DisplayName" SelectedValuePath="Name" SelectedValue="{Binding Config.Media.AudioDevice}" IsEnabled="{Binding IsAudioSelectionEnabled}"/>
                        <Button Style="{StaticResource StandardButton}" Grid.Row="0" Grid.Column="2" Width="35" Height="35" Click="BtnRefreshAudio_Click" Padding="0" IsEnabled="{Binding IsAudioSelectionEnabled}">
                            <TextBlock Text="🔄" FontSize="18"/>
                        </Button>

                        <TextBlock Style="{StaticResource StandardTextBlock}" Text="{x:Static loc:Strings.LblVideoSource}" Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" FontWeight="Normal"/>
                        <ComboBox Style="{StaticResource StandardComboBox}" x:Name="ComboVideo" Grid.Row="1" Grid.Column="1" ItemsSource="{Binding VideoWindows}" DisplayMemberPath="DisplayName" SelectedValuePath="ProcessName" SelectedValue="{Binding Config.Media.VideoWindow}" IsEnabled="{Binding IsVideoSelectionEnabled}"/>
                        <Button Style="{StaticResource StandardButton}" Grid.Row="1" Grid.Column="2" Width="35" Height="35" Click="BtnRefreshVideo_Click" Padding="0" IsEnabled="{Binding IsVideoSelectionEnabled}">
                            <TextBlock Text="🔄" FontSize="18"/>
                        </Button>

                        <TextBlock Style="{StaticResource StandardTextBlock}" Text="{x:Static loc:Strings.LblSlotLimit}" Grid.Row="2" Grid.Column="0" VerticalAlignment="Center" FontWeight="Normal"/>
                        <TextBox x:Name="TxtMaxSlots" Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="2" Margin="5" Padding="5" Text="{Binding Config.Session.MaxSlots, UpdateSourceTrigger=PropertyChanged}"/>

                        <TextBlock Style="{StaticResource StandardTextBlock}" Text="{x:Static loc:Strings.LblTimeout}" Grid.Row="3" Grid.Column="0" VerticalAlignment="Center" FontWeight="Normal"/>
                        <TextBox x:Name="TxtIdleTime" Grid.Row="3" Grid.Column="1" Grid.ColumnSpan="2" Margin="5" Padding="5" Text="{Binding Config.Session.IdleTime, UpdateSourceTrigger=PropertyChanged}">
                            <TextBox.Style>
                                <Style TargetType="TextBox">
                                    <Setter Property="IsEnabled" Value="True"/>
                                    <Setter Property="Background" Value="White"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Config.Session.UseDynamicTimeout}" Value="True">
                                            <Setter Property="IsEnabled" Value="False"/>
                                            <Setter Property="Background" Value="#444444"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBox.Style>
                        </TextBox>

                        <CheckBox x:Name="ChkDynamicTimeout" Content="{x:Static loc:Strings.LblDynamicTimeout}" Foreground="White" Grid.Row="4" Grid.Column="1" Grid.ColumnSpan="2" Margin="5" VerticalAlignment="Center" IsChecked="{Binding Config.Session.UseDynamicTimeout}"/>
                        <CheckBox x:Name="ChkSilentSync" Content="Vincular sessões automaticamente (Silent Sync)" Foreground="White" Grid.Row="15" Grid.Column="1" Grid.ColumnSpan="2" Margin="5,0,5,0" HorizontalAlignment="Right" VerticalAlignment="Center" IsChecked="{Binding Config.Session.SilentSync}"/>

                        <TextBlock Style="{StaticResource StandardTextBlock}" Text="{x:Static loc:Strings.LblLanguage}" Grid.Row="5" Grid.Column="0" VerticalAlignment="Center" FontWeight="Normal"/>
                        <ComboBox Style="{StaticResource StandardComboBox}" x:Name="ComboLanguage" Grid.Row="5" Grid.Column="1" Grid.ColumnSpan="2" SelectionChanged="ComboLanguage_SelectionChanged" SelectedValuePath="Tag" SelectedValue="{Binding Config.General.Language}">
                            <ComboBoxItem Content="English" Tag="en-US"/>
                            <ComboBoxItem Content="Español" Tag="es-ES"/>
                            <ComboBoxItem Content="Português" Tag="pt-BR"/>
                        </ComboBox>

                        <TextBlock Style="{StaticResource StandardTextBlock}" Text="{x:Static loc:Strings.LblAudioQuality}" Grid.Row="7" Grid.Column="0" VerticalAlignment="Center" FontWeight="Normal"/>
                        <ComboBox Style="{StaticResource StandardComboBox}" x:Name="ComboAudioRes" Grid.Row="7" Grid.Column="1" Grid.ColumnSpan="2" SelectedValuePath="Tag" SelectedValue="{Binding Config.Media.AudioBitrate}">
                            <ComboBoxItem Content="MP3 192 kbps (HQ)" Tag="192"/>
                            <ComboBoxItem Content="MP3 128 kbps (Default)" Tag="128"/>
                            <ComboBoxItem Content="MP3 96 kbps (Small)" Tag="96"/>
                            <ComboBoxItem Content="MP3 64 kbps (Tiny)" Tag="64"/>
                        </ComboBox>

                        <CheckBox x:Name="ChkOpenSettings" Content="{x:Static loc:Strings.LblOpenSettingsOnStartup}" Foreground="White" Grid.Row="8" Grid.Column="1" Grid.ColumnSpan="2" Margin="5,15,5,5" VerticalAlignment="Center" IsChecked="{Binding Config.General.OpenSettingsOnStartup}"/>

                        <Border Grid.Row="9" Grid.ColumnSpan="3" BorderBrush="#333333" BorderThickness="0,1,0,0" Margin="0,15,0,10" />

                        <TextBlock Style="{StaticResource StandardTextBlock}" Text="Auto Launch Hooker:" Grid.Row="10" Grid.Column="0" VerticalAlignment="Center" FontWeight="Normal"/>
                        <ComboBox Style="{StaticResource StandardComboBox}" Grid.Row="10" Grid.Column="1" Grid.ColumnSpan="2" SelectedValuePath="Tag" SelectedValue="{Binding Config.Hook.AutoLaunchHooker}">
                            <ComboBoxItem Content="None" Tag="None"/>
                            <ComboBoxItem Content="Textractor" Tag="Textractor"/>
                            <ComboBoxItem Content="LunaTranslator" Tag="LunaTranslator"/>
                        </ComboBox>

                        <TextBlock Style="{StaticResource StandardTextBlock}" Text="Textractor Base Path:" Grid.Row="11" Grid.Column="0" VerticalAlignment="Center" FontWeight="Normal"/>
                        <TextBox Grid.Row="11" Grid.Column="1" Grid.ColumnSpan="2" Margin="5" Padding="5" Text="{Binding Config.Hook.TextractorBasePath}" ToolTip="Folder containing x86 and x64 subfolders"/>

                        <TextBlock Style="{StaticResource StandardTextBlock}" Text="LunaTranslator Path:" Grid.Row="12" Grid.Column="0" VerticalAlignment="Center" FontWeight="Normal"/>
                        <TextBox Grid.Row="12" Grid.Column="1" Grid.ColumnSpan="2" Margin="5" Padding="5" Text="{Binding Config.Hook.LunaTranslatorPath}" ToolTip="Direct path to LunaTranslator.exe"/>

                        <TextBlock Style="{StaticResource StandardTextBlock}" Text="Text Hook Source:" Grid.Row="13" Grid.Column="0" VerticalAlignment="Center" FontWeight="Normal"/>
                        <ComboBox Style="{StaticResource StandardComboBox}" x:Name="ComboHookType" Grid.Row="13" Grid.Column="1" Grid.ColumnSpan="2" SelectedValuePath="Tag" SelectedValue="{Binding Config.Hook.ActiveHookType}" SelectionChanged="ComboHookType_SelectionChanged">
                            <ComboBoxItem Content="Clipboard" Tag="0"/>
                            <ComboBoxItem Content="WebSocket (Luna)" Tag="1"/>
                            <ComboBoxItem Content="WebSocket (Textractor)" Tag="2"/>
                        </ComboBox>

                        <TextBlock Style="{StaticResource StandardTextBlock}" x:Name="LblWsUrl" Text="WebSocket URL:" Grid.Row="14" Grid.Column="0" VerticalAlignment="Center" FontWeight="Normal"/>
                        <TextBox x:Name="TxtWsUrl" Grid.Row="14" Grid.Column="1" Grid.ColumnSpan="2" Margin="5" Padding="5" Text="{Binding Config.Hook.WebSocketUrl}" ToolTip="Luna: ws://localhost:2333/api/ws/text/origin | Textractor: ws://localhost:6677"/>
                    </Grid>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="{x:Static loc:Strings.HeaderAnki}">
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <Grid Margin="0,15,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Style="{StaticResource StandardTextBlock}" Text="{x:Static loc:Strings.LblDeck}" Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" FontWeight="Normal"/>
                        <ComboBox Style="{StaticResource StandardComboBox}" x:Name="ComboDeck" Grid.Row="0" Grid.Column="1" SelectedValue="{Binding Config.Anki.Deck}"/>
                        <Button Style="{StaticResource StandardButton}" Grid.Row="0" Grid.Column="2" Width="35" Height="35" Padding="0" Click="BtnRefreshAnki_Click">
                            <TextBlock Text="🔄" FontSize="18"/>
                        </Button>

                        <TextBlock Style="{StaticResource StandardTextBlock}" Text="{x:Static loc:Strings.LblNoteType}" Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" FontWeight="Normal"/>
                        <ComboBox Style="{StaticResource StandardComboBox}" x:Name="ComboModel" Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="2" SelectionChanged="ComboModel_SelectionChanged" SelectedValue="{Binding Config.Anki.Model}"/>

                        <TextBlock Style="{StaticResource StandardTextBlock}" Text="{x:Static loc:Strings.LblAudioField}" Grid.Row="2" Grid.Column="0" VerticalAlignment="Center" FontWeight="Normal"/>
                        <ComboBox Style="{StaticResource StandardComboBox}" x:Name="ComboFieldAudio" Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="2" SelectedValue="{Binding Config.Anki.AudioField}"/>

                        <TextBlock Style="{StaticResource StandardTextBlock}" Text="{x:Static loc:Strings.LblImageField}" Grid.Row="3" Grid.Column="0" VerticalAlignment="Center" FontWeight="Normal"/>
                        <ComboBox Style="{StaticResource StandardComboBox}" x:Name="ComboFieldImage" Grid.Row="3" Grid.Column="1" Grid.ColumnSpan="2" SelectedValue="{Binding Config.Anki.ImageField}"/>

                        <TextBlock Style="{StaticResource StandardTextBlock}" Text="AnkiConnect URL:" Grid.Row="4" Grid.Column="0" VerticalAlignment="Center" FontWeight="Normal"/>
                        <TextBox x:Name="TxtAnkiUrl" Grid.Row="4" Grid.Column="1" Grid.ColumnSpan="2" Margin="5" Padding="5" Text="{Binding Config.Anki.Url, UpdateSourceTrigger=PropertyChanged}"/>

                        <TextBlock Style="{StaticResource StandardTextBlock}" Text="{x:Static loc:Strings.LblTimeout}" Grid.Row="5" Grid.Column="0" VerticalAlignment="Center" FontWeight="Normal"/>
                        <TextBox x:Name="TxtAnkiTimeout" Grid.Row="5" Grid.Column="1" Grid.ColumnSpan="2" Margin="5" Padding="5" Text="{Binding Config.Anki.TimeoutSeconds, UpdateSourceTrigger=PropertyChanged}"/>

                        <!-- Yomitan Bridge Settings -->
                        <Border Grid.Row="6" Grid.ColumnSpan="3" BorderBrush="#333333" BorderThickness="0,1,0,0" Margin="0,15,0,10" />

                        <TextBlock Style="{StaticResource StandardTextBlock}" Text="{x:Static loc:Strings.LblYomitanBridgePort}" Grid.Row="8" Grid.Column="0" VerticalAlignment="Center" FontWeight="Normal"/>
                        <TextBox x:Name="TxtYomitanBridgePort" Grid.Row="8" Grid.Column="1" Grid.ColumnSpan="2" Margin="5" Padding="5" Text="{Binding Config.Anki.YomitanBridgePort, UpdateSourceTrigger=PropertyChanged}"/>
                    </Grid>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="Overlay">
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <Grid Margin="0,15,0,0" ClipToBounds="False">

                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Style="{StaticResource StandardTextBlock}" Text="Text Box BG:" Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" FontWeight="Normal"/>
                        <colorpicker:PortableColorPicker x:Name="PickerBgColor" Style="{StaticResource DefaultColorPickerStyle}" Grid.Row="0" Grid.Column="1" Margin="5" HorizontalAlignment="Left" Width="60" Height="30" />

                        <TextBlock Style="{StaticResource StandardTextBlock}" Text="Text Font Color:" Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" FontWeight="Normal"/>
                        <colorpicker:PortableColorPicker x:Name="PickerFontColor" Style="{StaticResource DefaultColorPickerStyle}" Grid.Row="1" Grid.Column="1" Margin="5" HorizontalAlignment="Left" Width="60" Height="30" />

                        <TextBlock Style="{StaticResource StandardTextBlock}" Text="Overlay Window BG:" Grid.Row="2" Grid.Column="0" VerticalAlignment="Center" FontWeight="Normal"/>
                        <colorpicker:PortableColorPicker x:Name="PickerOverlayBgColor" Style="{StaticResource DefaultColorPickerStyle}" Grid.Row="2" Grid.Column="1" Margin="5" HorizontalAlignment="Left" Width="60" Height="30" />

                        <TextBlock Style="{StaticResource StandardTextBlock}" Text="Font Size:" Grid.Row="3" Grid.Column="0" VerticalAlignment="Center" FontWeight="Normal"/>
                        <TextBox x:Name="TxtFontSize" Grid.Row="3" Grid.Column="1" Margin="5" Padding="5" Text="{Binding Config.Overlay.FontSize, UpdateSourceTrigger=PropertyChanged}"/>

                        <TextBlock Style="{StaticResource StandardTextBlock}" Text="Pass-Through Hold Key:" Grid.Row="4" Grid.Column="0" VerticalAlignment="Center" FontWeight="Normal"/>
                        <ComboBox Style="{StaticResource StandardComboBox}" x:Name="ComboPassModifier" Grid.Row="4" Grid.Column="1" Margin="5" Padding="5" SelectedValuePath="Tag" SelectedValue="{Binding Config.Overlay.PassThroughModifier}">
                            <ComboBoxItem Content="Ctrl" Tag="Ctrl"/>
                            <ComboBoxItem Content="Alt" Tag="Alt"/>
                            <ComboBoxItem Content="Shift" Tag="Shift"/>
                        </ComboBox>

                        <TextBlock Style="{StaticResource StandardTextBlock}" Text="Custom Extensions Paths:" Grid.Row="5" Grid.Column="0" VerticalAlignment="Center" FontWeight="Normal" Margin="5,15,5,5"/>
                        <StackPanel Orientation="Horizontal" Grid.Row="5" Grid.Column="1" HorizontalAlignment="Right" Margin="0,10,5,0">
                            <Button Style="{StaticResource StandardButton}" Content="⚙️" Width="30" Click="BtnExtensionSettings_Click" ToolTip="Open Yomitan Settings"/>
                            <Button Style="{StaticResource StandardButton}" Content="+" Width="30" Click="BtnAddExtension_Click" ToolTip="Add Custom Extension"/>
                            <Button Style="{StaticResource StandardButton}" Content="-" Width="30" Click="BtnRemoveExtension_Click" ToolTip="Remove Selected Extension"/>
                        </StackPanel>
                        <ListBox x:Name="ListExtensions" Grid.Row="6" Grid.Column="0" Grid.ColumnSpan="2" Margin="5" Background="#333" Foreground="White" BorderThickness="0"/>
                    </Grid>
                </ScrollViewer>
            </TabItem>
        </TabControl>

        <Button Content="{x:Static loc:Strings.BtnSaveClose}" Style="{StaticResource SaveButton}" Grid.Row="1" Click="BtnSave_Click"/>
    </Grid>
</Window>