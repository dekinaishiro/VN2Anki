<Window x:Class="VN2Anki.UserHubWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="VN2Anki - User Hub" Height="600" Width="900"
        Background="#1E1E1E" Foreground="White" WindowStartupLocation="CenterScreen">

    <Grid>
        <TabControl Background="Transparent" BorderThickness="0" Margin="10">
            <TabItem Header="📚 Library" Foreground="Black">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Orientation="Horizontal" Grid.Row="0" Margin="0,0,0,15">
                        <TextBox Width="300" Padding="5" Margin="0,0,10,0" Text="{Binding NewVnTitle, UpdateSourceTrigger=PropertyChanged}" TextWrapping="Wrap" VerticalContentAlignment="Center" />
                        <Button Content="Adicionar Nova VN" Command="{Binding AddVnCommand}" Padding="15,5" Background="#007ACC" Foreground="White" FontWeight="Bold" BorderThickness="0" Cursor="Hand"/>
                    </StackPanel>

                    <ListBox Grid.Row="1" ItemsSource="{Binding VisualNovels}" Background="#2D2D30" BorderThickness="0" Foreground="White" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Background="#3E3E42" CornerRadius="5" Margin="5" Padding="15" Width="800">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="{Binding Title}" FontSize="18" FontWeight="Bold"/>
                                            <TextBlock Text="{Binding ProcessName, StringFormat='Processo: {0}'}" Foreground="#AAAAAA" Margin="0,5,0,0"/>
                                        </StackPanel>

                                        <Button Grid.Column="1" Content="🗑 Excluir" Command="{Binding DataContext.DeleteVnCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}" Background="#DC3545" Foreground="White" FontWeight="Bold" BorderThickness="0" Padding="15,5" Cursor="Hand" VerticalAlignment="Center"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </TabItem>

            <TabItem Header="⏱️ Sessions History" Foreground="Black">
                <TextBlock Text="Histórico de sessões aparecerá aqui..." Foreground="Gray" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </TabItem>

            <TabItem Header="📊 Stats" Foreground="Black">
                <TextBlock Text="Gráficos e estatísticas aparecerão aqui..." Foreground="Gray" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </TabItem>
        </TabControl>
    </Grid>
</Window>